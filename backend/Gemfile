# gem 'jwt', '~> 2.7'  # Uncomment for JWT auth

# Background jobs (optional)
# gem 'sidekiq', '~> 7.2'
# gem 'redis', '~> 5.0'

# Performance & caching
gem 'bootsnap', require: false
